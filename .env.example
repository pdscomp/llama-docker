# llama-docker GPU backend configuration
# Copy this file to .env and customize, or run ./rc.prep to generate it interactively

# Backend: cuda | vulkan | rocm
GPU_BACKEND=vulkan

# Docker Compose file overlay (base + backend-specific)
COMPOSE_FILE=compose.yml:compose.vulkan.yml

# Docker image to use (format: llama.cpp:server-{backend}-{fork})
# Available images depend on what you've built with rc.build
LLAMA_IMAGE=llama.cpp:server-vulkan-upstream

# AMD GPU gfx version override (only needed for Vulkan/ROCm on AMD)
# Phoenix (780M, 7940HS): 11.0.2
# Strix Halo: 11.0.4
# RDNA3 discrete: 11.0.0 or 11.0.2
HSA_OVERRIDE_GFX_VERSION=11.0.2
